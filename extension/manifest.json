{
  "manifest_version": 3,
  "name": "LeetCode → LinkedIn Auto Post Generator",
  "version": "2.0.0",
  "description": "Auto-capture LeetCode split-screen screenshots and generate LinkedIn challenge posts",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
 "host_permissions": [
  "https://leetcode.com/*",
  "https://www.linkedin.com/*",
  "<all_urls>"
],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content/leetcode.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content/linkedin.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
  "default_title": "LeetInk",
    "default_icon": {
      "16": "icons/icon1.png"
    }
  }
}
